pragma solidity ^0.8.26;

import "../base/Constants.sol";
import "../base/Errors.sol";
import {VerificationBuilder} from "../builder/VerificationBuilder.presl";

/// @title OrderByExec
/// @dev Library for handling order by execution plans
library OrderByExec {
    /// @notice Evaluates an order by execution plan
    /// @custom:as-yul-wrapper
    /// #### Wrapped Yul Function
    /// ##### Signature
    /// ```yul
    /// order_by_exec_evaluate(plan_ptr, builder_ptr) -> plan_ptr_out, evaluations_ptr, output_length, output_chi_eval
    /// ```
    /// ##### Parameters
    /// * `plan_ptr` - calldata pointer to the order by execution plan
    /// * `builder_ptr` - memory pointer to the verification builder
    /// ##### Return Values
    /// * `plan_ptr_out` - pointer to the remaining plan after consuming the order by execution plan
    /// * `evaluations_ptr` - pointer to the evaluations
    /// * `output_length` - the number of rows of the output
    /// * `output_chi_eval` - pointer to the evaluation of a column of 1s with same length as output
    /// @notice Evaluates a order by execution plan
    /// @param __plan The order by execution plan data
    /// @param __builder The verification builder
    /// @return __planOut The remaining plan after processing
    /// @return __builderOut The verification builder result
    /// @return __evaluationsPtr The evaluations pointer
    /// @return __outputLength The length of the output chi evaluation
    /// @return __outputChiEvaluation The output chi evaluation
    function __orderByExecEvaluate( // solhint-disable-line gas-calldata-parameters
    bytes calldata __plan, VerificationBuilder.Builder memory __builder)
        external
        pure
        returns (
            bytes calldata __planOut,
            VerificationBuilder.Builder memory __builderOut,
            uint256[] memory __evaluationsPtr,
            uint256 __outputLength,
            uint256 __outputChiEvaluation
        )
    {
        uint256[] memory __evaluations;
        assembly {
            // import err from ../base/Errors.sol
            // import min, submod_bn254, mulmod_bn254, compute_fold from ../base/MathUtil.presl
            // import builder_consume_challenge, builder_consume_chi_evaluation_with_length from ../builder/VerificationBuilder.presl
            // import fold_first_round_mles from ../proof_gadgets/FoldUtil.presl
            // import permutation_check_evaluate from ../proof_gadgets/PermutationCheck.presl
            // import verify_filter from ../proof_gadgets/FilterBase.presl
            // import proof_plan_evaluate from ProofPlan.presl

            function order_by_exec_evaluate(plan_ptr, builder_ptr) -> plan_ptr_out, evaluations_ptr, output_length, output_chi_eval {
                // plan_ptr_out is being used instead of alpha for variable re-use
                plan_ptr_out := builder_consume_challenge(builder_ptr)
                let beta := builder_consume_challenge(builder_ptr)
                let input_evaluations_ptr
                plan_ptr, input_evaluations_ptr, output_length, output_chi_eval :=
                    proof_plan_evaluate(plan_ptr, builder_ptr)

                // For now, we only support ordering on exactly one column
                if sub(mload(plan_ptr), 1) { err(ERR_NUMBER_OF_ORDER_BY_COLUMNS_NOT_ONE) }
                plan_ptr := add(plan_ptr, WORD_SIZE)

                let sort_expr_eval
                plan_ptr, sort_expr_eval := proof_expr_evaluate(plan_ptr, builder_ptr, output_chi_eval, input_evaluations_ptr)
                
                {
                    let num_columns := mload(input_evaluations_ptr)
                    input_evaluations_ptr := add(input_evaluations_ptr, WORD_SIZE)
                    evaluations_ptr := mload(FREE_PTR)
                    mstore(FREE_PTR, add(evaluations_ptr, mul(add(num_columns, 2), WORD_SIZE)))
                    mstore(evaluations_ptr, add(num_columns, 1))
                    mcopy(add(evaluations_ptr, WORD_SIZE), input_evaluations_ptr, mul(num_columns, WORD_SIZE))
                    mstore(add(evaluations_ptr, mul(add(num_columns, 1), WORD_SIZE)), sort_expr_eval)
                    // plan_ptr_out is being used instead of alpha for variable re-use
                    evaluations_ptr := permutation_check_evaluate(builder_ptr, plan_ptr_out, beta, output_chi_eval, evaluations_ptr, output_length)

                    // Pop the sort eval
                    sort_expr_eval := mload(add(evaluations_ptr, mul(add(num_columns, 1), WORD_SIZE)))
                    mstore(evaluations_ptr, num_columns)
                }

                // plan_ptr_out is being used instead of alpha for variable re-use
                monotonic_verify(builder_ptr, plan_ptr_out, beta, sort_expr_eval, output_chi_eval, false, shr(mload(plan_ptr), BOOLEAN_PADDING_BITS))
                plan_ptr_out := add(plan_ptr, 1)
            }

            let __planOutOffset
            __planOutOffset, __evaluations, __outputLength, __outputChiEvaluation :=
                order_by_exec_evaluate(__plan.offset, __builder)
            __planOut.offset := __planOutOffset
            // slither-disable-next-line write-after-write
            __planOut.length := sub(__plan.length, sub(__planOutOffset, __plan.offset))
        }
        __evaluationsPtr = __evaluations;
        __builderOut = __builder;
    }
}
